{
	auto_https disable_redirects
}

:80 {
	root * ./html
	file_server
}

auth.nano-exp.com:80 {
	reverse_proxy 127.0.0.1:3500 {
		header_up Host {host}
		header_up X-Real-IP {remote}
	}
}

