tun.nano.properties:80 {
	handle {
		forward_auth 127.0.0.1:3500 {
			uri /api/protected
			header_up Host auth.nano.properties
			header_up X-Original-URI {scheme}://{host}{uri}
			@error status 401 403
			handle_response @error {
				redir https://auth.nano.properties/login?redirect={scheme}://{host}{uri}
			}
		}
		reverse_proxy 127.0.0.1:5500 {
			header_up Host {host}
			header_up X-Real-IP {remote}
		}
	}
}

code.nano.properties:80 {
	@bypass path /pty/* /site.webmanifest
	handle @bypass {
		reverse_proxy 127.0.0.1:4096 {
			header_up Host {host}
			header_up X-Real-IP {remote}
		}
	}
	handle {
		forward_auth 127.0.0.1:3500 {
			uri /api/protected
			header_up Host auth.nano.properties
			header_up X-Original-URI {scheme}://{host}{uri}
			@error status 401 403
			handle_response @error {
				redir https://auth.nano.properties/login?redirect={scheme}://{host}{uri}
			}
		}

		header -Content-Security-Policy
		reverse_proxy 127.0.0.1:4096 {
			header_up Host {host}
			header_up X-Real-IP {remote}
		}
	}
}

