s.nano.properties, static.nano.properties {
    root * ./html
    try_files {path} {path}/index.html
    file_server browse
}

tun.nano.properties {
	handle {
		forward_auth 127.0.0.1:3500 {
			uri /api/protected
			header_up Host auth.nano.properties
			header_up X-Original-URI {scheme}://{host}{uri}
			@error status 401 403
			handle_response @error {
				redir https://auth.nano.properties/login?redirect={scheme}%3A%2F%2F{host}{%uri}
			}
		}
		reverse_proxy 127.0.0.1:5500 {
			header_up Host {host}
			header_up X-Real-IP {client_ip}
		}
	}
}

code.nano.properties {
	@bypass path /pty/* /site.webmanifest
	handle @bypass {
		reverse_proxy 127.0.0.1:4096 {
			header_up Host {host}
			header_up X-Real-IP {client_ip}
		}
	}
	handle {
		forward_auth 127.0.0.1:3500 {
			uri /api/protected
			header_up Host auth.nano.properties
			header_up X-Original-URI {scheme}://{host}{uri}
			@error status 401 403
			handle_response @error {
				redir https://auth.nano.properties/login?redirect={scheme}%3A%2F%2F{host}{%uri}
			}
		}

		header -Content-Security-Policy
		reverse_proxy 127.0.0.1:4096 {
			header_up Host {host}
			header_up X-Real-IP {client_ip}
		}
	}
}

